{
	"name": "Farzetki BloodMoon Theme",
	"colors": {
		"editor.background": "#120808",
		"editor.foreground": "#ffb3b3",
		"activityBar.background": "#1c0d0d",
		"sideBar.background": "#1c0d0d",
		"statusBar.background": "#4d0f0f",
		"tab.activeBackground": "#2e1212",
		"titleBar.activeBackground": "#120808", // Uygulama aktifken (kullanıyorken) barın arka plan rengi
		"titleBar.inactiveBackground": "#0a0404", // Başka bir uygulamaya geçtiğinde barın alacağı flu renk
		"titleBar.activeForeground": "#ff2a2a", // Barın üstündeki yazıların ve ikonların rengi (beyaz)
		"statusBar.noFolderBackground": "#1c0d0d", // Hiçbir klasör açık değilken arkadaki renk (Şu anki mor kısım)
		"statusBar.debuggingBackground": "#ff2a2a", // Uygulama çalıştırırken/debug yaparkenki arka plan rengi
		"statusBar.foreground": "#ffb3b3",
		"activityBar.foreground": "#ff2a2a", // Tıklanmış/Aktif olan ikonun rengi
		"activityBar.inactiveForeground": "#8c4444", // Tıklanmamış/Pasif olan diğer ikonların rengi (biraz daha flu bir mavi verebilirsin)
		"activityBar.activeBorder": "#ff2a2a", // Aktif ikonun solunda çıkan ince çizginin (border) rengi
		"activityBarBadge.background": "#ff2a2a", // İkonların üstünde çıkan bildirim sayısının (Örn: 3 hata var) arka planı
		"activityBarBadge.foreground": "#120808", // Bildirim sayısının kendi yazı rengi (okunması için koyu lacivert yapabiliriz)
		"menu.background": "#1c0d0d", // Açılır menünün arka plan rengi (Activity bar ile aynı lacivert)
		"menu.foreground": "#ff2a2a", // Menüdeki yazıların rengi
		"menu.selectionBackground": "#ff2a2a", // Fareyle bir seçeneğin (Örn: üstüne geldiğin "Auto Save"in) üstüne gelince arka plan rengi
		"menu.selectionForeground": "#120808", // Fareyle üstüne geldiğin seçeneğin yazı rengi (Arka plan neon olacağı için içini siyahımsı/koyu lacivert yaptık)
		"menu.separatorBackground": "#8c4444", // Menüdeki araları bölen ince yatay çizgilerin rengi
		"menubar.selectionBackground": "#1c0d0d", // En üstteki "File", "Edit" yazılarının üstüne tıklayınca seçili kalan arka plan rengi
		"menubar.selectionForeground": "#ff2a2a", // En üstteki "File", "Edit" yazılarının üstüne tıklayınca aktifleşen rengi
		"foreground": "#ffb3b3", // Uygulama genelinde (Ayarlar sayfası açıklamaları dahil) varsayılan düz yazı rengi (okunabilir buz mavisi önerimdir)
		"descriptionForeground": "#b38080", // Ayarların altındaki uzun küçük açıklama metinlerinin rengi (Biraz daha flu yaparsak başlıklar öne çıkar)
		"settings.headerForeground": "#ff2a2a", // Ayarlar sayfasındaki büyük başlıklar ve kategori isimleri (Örn: "Text Editor", "Workbench")
		"settings.modifiedItemIndicator": "#ff2a2a", // Ayar değiştirdiğinde solunda beliren dikey ufak çizginin rengi
		"editorGroupHeader.tabsBackground": "#120808", // Sekmelerin arkasında kalan genel boşluğun arka planı
		"tab.inactiveBackground": "#1c0d0d", // Şu an tıklanmamış olan ("Welcome" gibi) ölü sekmelerin arka planı
		"tab.inactiveForeground": "#8c4444", // Tıklanmamış sekmelerin yazı rengi (odak dağıtmaması için biraz koyulaştırıyoruz)
		"list.activeSelectionBackground": "#2e1212", // Dosya menüsü aktifken (fareyle vs. oradayken) seçili dosyanın arka plan rengi
		"list.activeSelectionForeground": "#ff2a2a", // Dosya menüsü aktifken seçili dosyanın yazı rengi
		"list.inactiveSelectionBackground": "#1c0d0d", // Dosya menüsünde bir şey seçiliyken SEN KOD YAZIYORSAN (yani odak o menüde değilken - tam olarak attığın görseldeki durum) arka planı
		"list.inactiveSelectionForeground": "#ffb3b3", // Odak dışı seçili dosyanın yazı rengi
		"list.hoverBackground": "#240f0f", // Fareyle tıklamadan sadece üzerine geldiğinde oluşacak hafif parlama rengi
		"list.hoverForeground": "#ff2a2a", // Üzerine geldiğin dosya isminin rengi (şöyle hafif neon parlaması çok hoş durur)
		"input.background": "#120808", // Yazı yazdığın o metin kutusunun ("Describe what to build" yazan yerin) arka planı
		"input.foreground": "#ffb3b3", // O kutuya senin klavyeyle yazdığın metnin rengi
		"input.placeholderForeground": "#8c4444", // Kutunun içindeki "Describe what to build" gibi ipucu/silik yazıların rengi
		"input.border": "#ff2a2a", // Kutunun etrafındaki ince çizgi (dilersen kaldırabilirsin ama camgöbeği çizgi bence oraya çok yakışır)
		"editorWidget.background": "#1c0d0d", // O "Tip:" yazan üst kısımlar gibi genel araç kutularının/popupların arka planları
		"editorWidget.border": "#2e1212", // Araç kutularının çerçeve rengi
		"panel.background": "#120808" // Eğer sağdaki panelin genel arkaplanında sırıtan bir yer varsa onu da temanın ana rengine bağlar
	,
		"button.background": "#ff2a2a",
		"button.foreground": "#120808",
		"button.hoverBackground": "#ffb3b3",
		"dropdown.background": "#1c0d0d",
		"dropdown.foreground": "#ffb3b3",
		"dropdown.border": "#ff2a2a",
		"editorLineNumber.foreground": "#8c4444",
		"editorLineNumber.activeForeground": "#ff2a2a",
		"scrollbarSlider.background": "#ff2a2a30",
		"scrollbarSlider.hoverBackground": "#ff2a2a60",
		"scrollbarSlider.activeBackground": "#ff2a2a90",
		"editorSuggestWidget.background": "#1c0d0d",
		"editorSuggestWidget.selectedBackground": "#ff2a2a",
		"editorSuggestWidget.foreground": "#ffb3b3",
		"editorSuggestWidget.border": "#ff2a2a",
		"terminal.background": "#120808",
		"terminal.foreground": "#ffb3b3",
		"gitDecoration.modifiedResourceForeground": "#ff7777",
		"gitDecoration.untrackedResourceForeground": "#ffaa00",
		"gitDecoration.deletedResourceForeground": "#ff5555",
		"editor.selectionBackground": "#ff2a2a40",
		"editor.selectionHighlightBackground": "#ff2a2a20",
		"editor.inactiveSelectionBackground": "#ff2a2a20"
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#8c4444"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"string constant.other.placeholder"
			],
			"settings": {
				"foreground": "#ff7777"
			}
		},
		{
			"name": "Colors",
			"scope": [
				"constant.other.color"
			],
			"settings": {
				"foreground": "#ffaa00"
			}
		},
		{
			"name": "Invalid",
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#ffb3b3"
			}
		},
		{
			"name": "Keyword, Storage",
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#ff2a2a"
			}
		},
		{
			"name": "Operator, Misc",
			"scope": [
				"keyword.control",
				"constant.other.color",
				"punctuation",
				"meta.tag",
				"punctuation.definition.tag",
				"punctuation.separator.inheritance.php",
				"punctuation.definition.tag.html",
				"punctuation.definition.tag.begin.html",
				"punctuation.definition.tag.end.html",
				"punctuation.section.embedded",
				"keyword.other.template",
				"keyword.other.substitution"
			],
			"settings": {
				"foreground": "#ff2a2a"
			}
		},
		{
			"name": "Tag",
			"scope": [
				"entity.name.tag",
				"meta.tag.sgml",
				"markup.deleted.git_gutter"
			],
			"settings": {
				"foreground": "#ff2a2a"
			}
		},
		{
			"name": "Function, Special Method",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"variable.function",
				"support.function",
				"keyword.other.special-method"
			],
			"settings": {
				"foreground": "#ff5555"
			}
		},
		{
			"name": "Block Level Variables",
			"scope": [
